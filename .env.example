# Global
APP_ENV=local

# Auth / backend placeholders
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_JWT_ISSUER=http://supabase-kong:8000/auth/v1
SUPABASE_JWT_SECRET=replace-with-dev-jwt-secret
SUPABASE_ANON_KEY=replace-with-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-dev-service-role-key

# Database (local example)
SUPABASE_DB_JDBC_URL=jdbc:postgresql://supabase-db:5432/postgres
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace-with-dev-db-password

# Frontend
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-dev-anon-key
NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Admin Angular
ADMIN_API_BASE_URL=http://localhost:8080
ADMIN_SUPABASE_URL=http://localhost:54321

# Billing integration placeholder
STRIPE_SECRET_KEY=replace-with-dev-stripe-key
STRIPE_WEBHOOK_SECRET=replace-with-dev-webhook-secret

# Messaging / search infra
KAFKA_BROKERS=localhost:9092

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=replace-with-dev-opensearch-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail / notifications
MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025

# Geo Service API
NEXT_PUBLIC_GEO_API_BASE=http://localhost:8087
